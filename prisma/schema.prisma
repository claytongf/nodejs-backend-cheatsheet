// Prisma schema for the Task Manager API.
// Docs: https://www.prisma.io/docs
// After editing, run: npm run prisma:migrate
//
// This phase introduces the Task model. The User and Project models (and the
// ownership relations) are added in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
